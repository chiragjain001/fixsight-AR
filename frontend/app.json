{
  "expo": {
    "name": "fixsight-ar",
    "slug": "fixsight-ar",
    "scheme": "fixsight",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "FixSight needs camera access to detect hazards.",
        "NSMicrophoneUsageDescription": "FixSight needs microphone access to transcribe voice messages into text.",
        "NSLocationWhenInUseUsageDescription": "Required for AR world tracking accuracy."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.INTERNET"
      ],
      "minSdkVersion": 24,
      "package": "com.chirag_jain.fixsighttemp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "FixSight needs camera access to detect hazards.",
          "enableFrameProcessors": true
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "FixSight needs microphone access to transcribe voice messages into text."
        }
      ],
      "expo-sqlite",
      "expo-router",
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.1.0"
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0eb3d3d5-5d36-4e61-a8eb-1d231e636ab5"
      }
    },
    "owner": "chirag_jain"
  }
}
